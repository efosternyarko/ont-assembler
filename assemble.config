// ── assemble.config — configuration for the standalone ONT assembly pipeline ──
//
// Usage:
//   nextflow run assemble.nf -c assemble.config [options]
//
// The -c flag is optional if assemble.config is in the same directory and
// Nextflow picks it up automatically.  To be explicit, always pass it.

// ── Default parameters ────────────────────────────────────────────────────────
params {
    help          = false

    // Input — one of these is required
    samplesheet   = null   // CSV with columns: id,reads
    input_dir     = null   // Directory of FASTQ / FASTQ.gz files

    // Output — default includes assembler name to prevent runs from colliding
    outdir        = null   // set dynamically in assemble.nf to "assembly_results_${assembler}"

    // Assembler
    assembler          = 'hybracter'   // hybracter | flye | raven

    // Read QC / depth filter / subsampling
    genome_size        = '5m'          // Expected genome size (e.g. 5m, 4500000)
    min_read_depth     = 20            // Minimum estimated depth (×) to proceed with assembly
    max_depth          = 100           // Subsample reads above this depth (×) with rasusa before assembly

    // Hybracter-specific
    chromosome_size    = 2500000       // Min contig length to call a chromosome (bp)
                                       // Ignored when hybracter_auto = true
    hybracter_auto     = true          // Let hybracter estimate chromosome length (--auto)
    hybracter_no_medaka = false        // Skip medaka polishing — set true on macOS ARM

    // Resources
    max_cpus   = 16
    max_memory = '128.GB'
}

// ── Process defaults ──────────────────────────────────────────────────────────
process {
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
        mode: 'copy'
    ]

    errorStrategy = { task.exitStatus in [1, 2, 14] ? 'ignore' : 'terminate' }
    maxRetries    = 1

    withLabel: 'low' {
        cpus   = 1
        memory = '4 GB'
        time   = '1h'
    }
    withLabel: 'medium' {
        cpus   = { Math.min(4, params.max_cpus as int) }
        memory = '8 GB'
        time   = '4h'
    }
    withLabel: 'high' {
        cpus   = { Math.min(8, params.max_cpus as int) }
        memory = '20 GB'
        time   = '8h'
    }

    // Hybracter: route files to named subdirectories via saveAs.
    //   all_assemblies/   — merged chr+plasmid FASTA per sample (feed into enteric-typer)
    //   hybracter_output/ — per-sample chromosome, plasmid, and incomplete FASTAs + summary TSVs
    withName: 'HYBRACTER_ASSEMBLY' {
        publishDir = [
            path: { "${params.outdir}" },
            mode: 'copy',
            saveAs: { filename ->
                if (filename.endsWith('_chromosome.fasta') ||
                    filename.endsWith('_plasmid.fasta')    ||
                    filename.endsWith('_incomplete.fasta') ||
                    filename.endsWith('_hybracter_summary.tsv')) {
                    "hybracter_output/${filename}"
                } else if (filename.endsWith('.fasta')) {
                    "all_assemblies/${filename}"
                } else if (filename.endsWith('_flye.gfa')) {
                    "hybracter_output/${filename}"
                } else if (filename.endsWith('_timing.tsv')) {
                    "assembly_timing/${filename}"
                } else {
                    null
                }
            }
        ]
    }

    // Other assemblers: assembled FASTAs to assemblies/, logs/info to tool-named dir,
    // per-sample timing TSVs to assembly_timing/
    withName: 'FLYE_ASSEMBLY|RAVEN_ASSEMBLY' {
        publishDir = [
            [
                path: { "${params.outdir}/assemblies" },
                mode: 'copy',
                pattern: '*.fasta'
            ],
            [
                path: { "${params.outdir}/${task.process.tokenize(':')[-1].toLowerCase()}" },
                mode: 'copy',
                pattern: '*.{log,txt,gfa}'
            ],
            [
                path: { "${params.outdir}/assembly_timing" },
                mode: 'copy',
                pattern: '*_timing.tsv'
            ]
        ]
    }
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {

    conda {
        conda.enabled  = true
        conda.useMamba = false
    }

    mamba {
        conda.enabled  = true
        conda.useMamba = true
    }

    // macOS Apple Silicon — combine with conda or mamba:
    //   CONDA_SUBDIR=osx-64 nextflow run assemble.nf -profile conda,arm64 ...
    arm64 {
        conda.createOptions = '--platform osx-64'
        env.CONDA_SUBDIR    = 'osx-64'
    }

    docker {
        docker.enabled      = true
        docker.fixOwnership = true
        docker.runOptions   = '-u $(id -u):$(id -g)'
    }

    singularity {
        singularity.enabled    = true
        singularity.autoMounts = true
        singularity.cacheDir   = "${HOME}/.singularity/cache"
        singularity.pullTimeout = '2h'
    }

    slurm {
        process.executor = 'slurm'
        process.queue    = 'comp'
        withLabel: 'low'    { cpus = 2;  memory = '4 GB';  time = '1h'  }
        withLabel: 'medium' { cpus = 4;  memory = '16 GB'; time = '4h'  }
        withLabel: 'high'   { cpus = 16; memory = '64 GB'; time = '12h' }
    }

    pbs {
        process.executor = 'pbs'
        process.queue    = 'normal'
        withLabel: 'low'    { cpus = 2;  memory = '4 GB';  time = '1h'  }
        withLabel: 'medium' { cpus = 8;  memory = '16 GB'; time = '4h'  }
        withLabel: 'high'   { cpus = 16; memory = '64 GB'; time = '12h' }
    }
}

// ── Reporting ─────────────────────────────────────────────────────────────────
timeline {
    enabled  = true
    file     = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}
report {
    enabled  = true
    file     = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}
dag {
    enabled  = true
    file     = "${params.outdir}/pipeline_info/dag.svg"
    overwrite = true
}
